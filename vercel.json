{
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server.js": {
      "includeFiles": "portfolio.db",
      "maxDuration": 10
    },
    "api/**/*.js": {
      "includeFiles": "portfolio.db",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ],
  "cleanUrls": true
}